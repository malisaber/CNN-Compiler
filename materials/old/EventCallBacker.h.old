	void Add_CallBack(volatile unsigned int * new_add, int new_pos, void(*new_callback)(int, int), int new_arg1, int new_arg2);
	void Chk_CallBack();
	int  CHk_CallBack_NB();

private:
	void CHk_CallBack_NBUS();
};

