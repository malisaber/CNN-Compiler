
#include <new>
#include "uprint.h"
#include "Utilities.h"
#include "Accelerator.h"
#include "EventCallBacker.h"


void intr_PC		(unsigned int intr_addr);
void intr_TBE		(unsigned int intr_addr);
void intr_RBF		(unsigned int intr_addr);
void intr_TXD		(unsigned int intr_addr);
void intr_RXD		(unsigned int intr_addr);
void intr_Timer		(unsigned int intr_addr);
void intr_MPDR		(unsigned int intr_addr);
void intr_DMA		(unsigned int intr_addr);
void intr_PLANE_0	(unsigned int intr_addr);
void intr_PLANE_1	(unsigned int intr_addr);
void intr_PLANE_2	(unsigned int intr_addr);
void intr_PLANE_3	(unsigned int intr_addr);
void (*funcPtrArray[12])(unsigned int);

unsigned int PC_INT_Cntr(0);
unsigned int TIMER_INT_Cntr(0);
unsigned int DMA_INT_Cntr(0);
unsigned int PLANE0_INT_Cntr(0);
unsigned int PLANE1_INT_Cntr(0);
unsigned int PLANE2_INT_Cntr(0);
unsigned int PLANE3_INT_Cntr(0);


alignas(EventCallBacker)
static unsigned char ECB_storage[sizeof(EventCallBacker)];
static EventCallBacker* ECB;

void DMA_CallBack_from_STA_P0	(int pe_add,	int Hist);
void DMA_CallBack_from_DMACB	(int plane,		int pe_add);

int main()
{	
	/*\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\
		Initiation
	/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/*/
	funcPtrArray[0]  = &intr_PC;
	funcPtrArray[1]  = &intr_TBE;
	funcPtrArray[2]  = &intr_RBF;
	funcPtrArray[3]  = &intr_TXD;
	funcPtrArray[4]  = &intr_RXD;
	funcPtrArray[5]  = &intr_Timer;
	funcPtrArray[6]  = &intr_MPDR;
	funcPtrArray[7]  = &intr_DMA;
	funcPtrArray[8]  = &intr_PLANE_0;
	funcPtrArray[9]  = &intr_PLANE_1;
	funcPtrArray[10] = &intr_PLANE_2;
	funcPtrArray[11] = &intr_PLANE_3;
	
	ECB = new (ECB_storage) EventCallBacker();

	/*\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\
		System Control
	/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/*/
	CONT_REG_DRAM_connect();
	CONT_REG_ACC_Plane_reset(PLANE_0);
	CONT_REG_ACC_Plane_normal(PLANE_0);


	/*\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\
		Interrupt Handlre Configuration
	/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/*/
	INTH_enable_intr_pc();
	INTH_enable_intr_timer_group	(0x01);
	INTH_enable_intr_DMA_done_group	(0X0000);
	INTH_enable_PSU_done_group		(PLANE_0,	0xFFFF);


	/*\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\
		Timer Configuration
	/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/*/
	//	for the given clk period tht is 10 ns,
	//	timer is set to generate interrupts every 1 ms
	TIMER_config(0, 99, 10, 1);
	TIMER_start	(0);

	
	/*\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\
		DMA Event Counter Configuration
	/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/*/
	//for (unsigned int pe_add=0; pe_add<16; pe_add++)
	//{
	//	DMA_EC_CNTR_config(pe_add, 1, 1, 1, 1);
	//	DMA_EC_CNTR_start(pe_add);
	//}
	

	/*\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\
		DMA Configuration
	/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/*/
	DMA_start_transfer(0,	0x00000000,	0xFFFF0000,	0x8FF);
	DMA_start_transfer(1,	0x10000000,	0xFFFF1000,	0x8FF);
	DMA_start_transfer(2,	0x20000000,	0xFFFF2000,	0x8FF);
	DMA_start_transfer(3,	0x30000000,	0xFFFF3000,	0x8FF);
	DMA_start_transfer(4,	0x40000000,	0xFFFF4000,	0x8FF);
	DMA_start_transfer(5,	0x50000000,	0xFFFF5000,	0x8FF);
	DMA_start_transfer(6,	0x60000000,	0xFFFF6000,	0x8FF);
	DMA_start_transfer(7,	0x70000000,	0xFFFF7000,	0x8FF);
	DMA_start_transfer(8,	0x80000000,	0xFFFF8000,	0x8FF);
	DMA_start_transfer(9,	0x90000000,	0xFFFF9000,	0x8FF);
	DMA_start_transfer(10,	0xA0000000,	0xFFFFA000,	0x8FF);
	DMA_start_transfer(11,	0xB0000000,	0xFFFFB000,	0x8FF);
	DMA_start_transfer(12,	0xC0000000,	0xFFFFC000,	0x8FF);
	DMA_start_transfer(13,	0xD0000000,	0xFFFFD000,	0x8FF);
	DMA_start_transfer(14,	0xE0000000,	0xFFFFE000,	0x8FF);
	DMA_start_transfer(15,	0xF0000000,	0xFFFFF000,	0x8FF);
	ECB->Add_CallBack(C_PERIPHERAL_REG_EVENT_COUNTER_DMA_0_DONE + 0,	C_Event_Event_Value_pos, DMA_CallBack_from_DMACB, PLANE_0, 0 );
	//ECB->Add_CallBack(C_PERIPHERAL_REG_EVENT_COUNTER_DMA_0_DONE + 1,	C_Event_Event_Value_pos, DMA_CallBack_from_DMACB, PLANE_0, 1 );
	//ECB->Add_CallBack(C_PERIPHERAL_REG_EVENT_COUNTER_DMA_0_DONE + 2,	C_Event_Event_Value_pos, DMA_CallBack_from_DMACB, PLANE_0, 2 );
	//ECB->Add_CallBack(C_PERIPHERAL_REG_EVENT_COUNTER_DMA_0_DONE + 3,	C_Event_Event_Value_pos, DMA_CallBack_from_DMACB, PLANE_0, 3 );
	//ECB->Add_CallBack(C_PERIPHERAL_REG_EVENT_COUNTER_DMA_0_DONE + 4,	C_Event_Event_Value_pos, DMA_CallBack_from_DMACB, PLANE_0, 4 );
	//ECB->Add_CallBack(C_PERIPHERAL_REG_EVENT_COUNTER_DMA_0_DONE + 5,	C_Event_Event_Value_pos, DMA_CallBack_from_DMACB, PLANE_0, 5 );
	//ECB->Add_CallBack(C_PERIPHERAL_REG_EVENT_COUNTER_DMA_0_DONE + 6,	C_Event_Event_Value_pos, DMA_CallBack_from_DMACB, PLANE_0, 6 );
	//ECB->Add_CallBack(C_PERIPHERAL_REG_EVENT_COUNTER_DMA_0_DONE + 7,	C_Event_Event_Value_pos, DMA_CallBack_from_DMACB, PLANE_0, 7 );
	//ECB->Add_CallBack(C_PERIPHERAL_REG_EVENT_COUNTER_DMA_0_DONE + 8,	C_Event_Event_Value_pos, DMA_CallBack_from_DMACB, PLANE_0, 8 );
	//ECB->Add_CallBack(C_PERIPHERAL_REG_EVENT_COUNTER_DMA_0_DONE + 9,	C_Event_Event_Value_pos, DMA_CallBack_from_DMACB, PLANE_0, 9 );
	//ECB->Add_CallBack(C_PERIPHERAL_REG_EVENT_COUNTER_DMA_0_DONE + 10,	C_Event_Event_Value_pos, DMA_CallBack_from_DMACB, PLANE_0, 10);
	//ECB->Add_CallBack(C_PERIPHERAL_REG_EVENT_COUNTER_DMA_0_DONE + 11,	C_Event_Event_Value_pos, DMA_CallBack_from_DMACB, PLANE_0, 11);
	//ECB->Add_CallBack(C_PERIPHERAL_REG_EVENT_COUNTER_DMA_0_DONE + 12,	C_Event_Event_Value_pos, DMA_CallBack_from_DMACB, PLANE_0, 12);
	//ECB->Add_CallBack(C_PERIPHERAL_REG_EVENT_COUNTER_DMA_0_DONE + 13,	C_Event_Event_Value_pos, DMA_CallBack_from_DMACB, PLANE_0, 13);
	//ECB->Add_CallBack(C_PERIPHERAL_REG_EVENT_COUNTER_DMA_0_DONE + 14,	C_Event_Event_Value_pos, DMA_CallBack_from_DMACB, PLANE_0, 14);
	//ECB->Add_CallBack(C_PERIPHERAL_REG_EVENT_COUNTER_DMA_0_DONE + 15,	C_Event_Event_Value_pos, DMA_CallBack_from_DMACB, PLANE_0, 15);
	





	/*\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\
		Config Holder Configuration
	/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/*/
	S_PE_cofig	Conf_P0_PE_0	=	{FSM_CNN_1,	16,	FULL,	IUNSIGN,	WUNSIGN,	0,	15,	15,	15,	15,	15};
	S_PE_cofig	Conf_P0_PE_1	=	{FSM_CNN_1,	16,	FULL,	IUNSIGN,	WUNSIGN,	0,	15,	15,	15,	15,	15};
	S_PE_cofig	Conf_P0_PE_2	=	{FSM_CNN_1,	16,	FULL,	IUNSIGN,	WUNSIGN,	0,	15,	15,	15,	15,	15};
	S_PE_cofig	Conf_P0_PE_3	=	{FSM_CNN_1,	16,	FULL,	IUNSIGN,	WUNSIGN,	0,	15,	15,	15,	15,	15};
	S_PE_cofig	Conf_P0_PE_4	=	{FSM_CNN_1,	16,	FULL,	IUNSIGN,	WUNSIGN,	0,	15,	15,	15,	15,	15};
	S_PE_cofig	Conf_P0_PE_5	=	{FSM_CNN_1,	16,	FULL,	IUNSIGN,	WUNSIGN,	0,	15,	15,	15,	15,	15};
	S_PE_cofig	Conf_P0_PE_6	=	{FSM_CNN_1,	16,	FULL,	IUNSIGN,	WUNSIGN,	0,	15,	15,	15,	15,	15};
	S_PE_cofig	Conf_P0_PE_7	=	{FSM_CNN_1,	16,	FULL,	IUNSIGN,	WUNSIGN,	0,	15,	15,	15,	15,	15};
	S_PE_cofig	Conf_P0_PE_8	=	{FSM_CNN_1,	16,	FULL,	IUNSIGN,	WUNSIGN,	0,	15,	15,	15,	15,	15};
	S_PE_cofig	Conf_P0_PE_9	=	{FSM_CNN_1,	16,	FULL,	IUNSIGN,	WUNSIGN,	0,	15,	15,	15,	15,	15};
	S_PE_cofig	Conf_P0_PE_10	=	{FSM_CNN_1,	16,	FULL,	IUNSIGN,	WUNSIGN,	0,	15,	15,	15,	15,	15};
	S_PE_cofig	Conf_P0_PE_11	=	{FSM_CNN_1,	16,	FULL,	IUNSIGN,	WUNSIGN,	0,	15,	15,	15,	15,	15};
	S_PE_cofig	Conf_P0_PE_12	=	{FSM_CNN_1,	16,	FULL,	IUNSIGN,	WUNSIGN,	0,	15,	15,	15,	15,	15};
	S_PE_cofig	Conf_P0_PE_13	=	{FSM_CNN_1,	16,	FULL,	IUNSIGN,	WUNSIGN,	0,	15,	15,	15,	15,	15};
	S_PE_cofig	Conf_P0_PE_14	=	{FSM_CNN_1,	16,	FULL,	IUNSIGN,	WUNSIGN,	0,	15,	15,	15,	15,	15};
	S_PE_cofig	Conf_P0_PE_15	=	{FSM_CNN_1,	16,	FULL,	IUNSIGN,	WUNSIGN,	0,	15,	15,	15,	15,	15};
	CONFH_set_conf(PLANE_0, 0x0,	Conf_P0_PE_0);
	CONFH_set_conf(PLANE_0, 0x1,	Conf_P0_PE_1);
	CONFH_set_conf(PLANE_0, 0x2,	Conf_P0_PE_2);
	CONFH_set_conf(PLANE_0, 0x3,	Conf_P0_PE_3);
	CONFH_set_conf(PLANE_0, 0x4,	Conf_P0_PE_4);
	CONFH_set_conf(PLANE_0, 0x5,	Conf_P0_PE_5);
	CONFH_set_conf(PLANE_0, 0x6,	Conf_P0_PE_6);
	CONFH_set_conf(PLANE_0, 0x7,	Conf_P0_PE_7);
	CONFH_set_conf(PLANE_0, 0x8,	Conf_P0_PE_8);
	CONFH_set_conf(PLANE_0, 0x9,	Conf_P0_PE_9);
	CONFH_set_conf(PLANE_0, 0xA,	Conf_P0_PE_10);
	CONFH_set_conf(PLANE_0, 0xB,	Conf_P0_PE_11);
	CONFH_set_conf(PLANE_0, 0xC,	Conf_P0_PE_12);
	CONFH_set_conf(PLANE_0, 0xD,	Conf_P0_PE_13);
	CONFH_set_conf(PLANE_0, 0xE,	Conf_P0_PE_14);
	CONFH_set_conf(PLANE_0, 0xF,	Conf_P0_PE_15);
	CONFH_refresh (PLANE_0);


	/*\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\
		Store Agent and Update Agent initiation
	/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/*/
	//	S_addressing_info 					{base,	count,	interval}
	S_Addressing_Info	SA_address	=	{0,		0xFF,	0x100};
	S_Addressing_Info	UA_wgt_addr[9];
	S_Addressing_Info	UA_inp_addr =	{0,		0xFF,	0X400};
	//	Store Agent initiation
	for (unsigned int pe_add=0; pe_add<16; pe_add++)
	{
		SA_address.base_add = 0xA000000 + pe_add*0x10000000;
		PE_INIT_SA_load_address(PLANE_0, pe_add, SA_address,  SA_address);
	}

	//	Update Agent initiation
	for (unsigned int j=0; j<9; j++)
	{
		UA_wgt_addr[j].count = 0XFF;
		UA_wgt_addr[j].interval = 0X900;
	}
	for (unsigned int pe_add=0; pe_add<16; pe_add++)
	{
		for (unsigned int j=0; j<9; j++)
		{
			UA_wgt_addr[j].base_add = 0xFFFF0000 + pe_add*0x1000 + j*0x100;
		}
		UA_inp_addr.base_add = 0x5000000 + pe_add*0x10000000 + j*0x100;
		PE_INIT_UA_load_address(PLANE_0, pe_add, UA_wgt_addr, UA_inp_addr);
	}
	

	/*\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\
		Plannar Event Counter Configuration
	/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/*/
	//	E_PSU_EC_target:
	//			0	->	PEs
	//			2	->	STA
	//			3	->	UPA
	for (unsigned int pe_add=0; pe_add<16; pe_add++)
	{
		//PSU_EC_CNTR_config(unsigned int plane_add, E_PSU_EC_target targ, unsigned int SEC_add, int max, int sens_level, int repeat, int intr_en)
		//PSU_EC_CNTR_config(PLANE_0, PEs, pe_add, 1, 1, 1, 1);
		//PSU_EC_CNTR_start	(PLANE_0, PEs, pe_add);
		PSU_EC_CNTR_config	(PLANE_0, STA, pe_add, 15, 1, 1, 1);
		PSU_EC_CNTR_start	(PLANE_0, STA, pe_add);
		//PSU_EC_CNTR_config(PLANE_0, UPA, pe_add, 1, 1, 1, 1);
		//PSU_EC_CNTR_start	(PLANE_0, UPA, pe_add);
	}


	/*\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\
		Plannar Processing Element Control
	/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/*/
	S_CONF_STA_info	STA_info;
	STA_info.update_store_address = 0;
	STA_info.update_load_address = 0;
	STA_info.store_enable = 1;
	STA_info.load_enable = 0;
	STA_info.activation_enable = 0;
	STA_info.save_on_buffer = 0;
	STA_info.accumulate_with_bias = 0;
	STA_info.accumulate_with_OBM = 1;
	STA_info.accumulate_with_buffer = 0;
	STA_info.Automatic = 1;
	for (unsigned int pe_add=0; pe_add<16; pe_add++)
	{
		PE_CONT_STA_load_config(PLANE_0, pe_add, STA_info);
		//	check its DMA for Transfer Completion
		DMA_wait_for_done(pe_add);
		PE_CONT_UPA_start_updating_WFM(PLANE_0, pe_add);
		PE_CONT_UPA_stop_updating_WFM (PLANE_0, pe_add);
		PE_CONT_UPA_start_updating_IFM(PLANE_0, pe_add);
		//PE_CONT_PE_inc_rows(PLANE_0, pe_add, 0, 1, 2);
	}
	for (unsigned int pe_add=0; pe_add<16; pe_add++)
	{
		PE_CONT_PE_start(PLANE_0, pe_add);
	}

	
	/*\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\
		infinity loop Checking CallBack List.
	/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/*/
	while(1)
	{
		ECB->Chk_CallBack();
	}

}


void EXT_INT_0_handler()
{
	unsigned int this_intr_addr;
	unsigned int this_intr_code;
	INTH_get_intr_address(this_intr_addr, this_intr_code);
	funcPtrArray[this_intr_code](this_intr_addr);
}

